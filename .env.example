# =====================================================
# Badassery PR — Environment Variables
# =====================================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git!
# =====================================================

# Google Gemini API (for AI categorization & matching)
# Get your key at: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Firebase Service Account
# Download from: Firebase Console > Settings > Service Accounts > Generate New Private Key
# Place the JSON file at the project root as serviceAccountKey.json
GOOGLE_APPLICATION_CREDENTIALS=./serviceAccountKey.json

# PodcastIndex API (for podcast metadata enrichment)
# Register at: https://api.podcastindex.org/
PODCASTINDEX_API_KEY=your_podcastindex_api_key_here
PODCASTINDEX_API_SECRET=your_podcastindex_api_secret_here

# Gmail SMTP (for email sending via Cloud Functions)
# Create an App Password at: https://myaccount.google.com/apppasswords
GMAIL_USER=your_email@gmail.com
GMAIL_PASSWORD=your_gmail_app_password_here
